%------------------------------
% Beamer Settings
%------------------------------

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerthemeSimpleUUlm}[2026/07/01 SimpleUUlm outer theme]

\mode<presentation>

% faculty=medicine|engineering|math|science|default, e.g.
% \usetheme[faculty=engineering]{SimpleUUlm}
\def\SimpleUUlm@faculty{default}
\DeclareOptionBeamer{faculty}{\def\SimpleUUlm@faculty{#1}}
\ProcessOptionsBeamer

\usefonttheme{SimpleUUlm}
\usecolortheme{SimpleUUlm}
\useinnertheme{SimpleUUlm}

\expandafter\setfacultycolor\expandafter{\SimpleUUlm@faculty}

\mode<all>
