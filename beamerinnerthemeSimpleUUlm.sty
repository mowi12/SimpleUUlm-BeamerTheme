%------------------------------
% Inner Theme Settings
%------------------------------

\ProvidesPackage{beamerinnerthemeSimpleUUlm}[2026/07/01 SimpleUUlm inner theme]

\RequirePackage{etoolbox}

% progressbar flag is normally set by the outer theme; default off when the
% inner theme is loaded on its own
\providecommand{\SimpleUUlm@pbenabled}{false}

\setbeamersize{text margin left=2em,text margin right=2em}

\setbeamertemplate{footline}[frame number]
\setbeamertemplate{navigation symbols}{}

\setbeamertemplate{blocks}[rounded][shadow=false]

\setbeamertemplate{enumerate items}[default]
\setbeamertemplate{enumerate subitem}[default]
\setbeamertemplate{itemize items}[circle]
\setbeamertemplate{itemize subitem}[circle]

% table of contents (overview) settings
\setbeamertemplate{section in toc}[sections numbered]
\setbeamertemplate{subsection in toc}{%
    \leavevmode
    \leftskip=3.2em
    \rlap{\hskip-2em\inserttocsectionnumber.\inserttocsubsectionnumber}%
    \inserttocsubsection\par
}

% section divider page: bold "Section N" above the title
\AtBeginSection[]{%
    \begin{frame}[plain,noframenumbering]
        \sectionpage
    \end{frame}%
}

% progress bar under the frametitle rule: muted track, institute-colored fill
% scaled by frame number/total (integer math avoids dimen overflow)
\newlength{\SimpleUUlm@pbheight}
\setlength{\SimpleUUlm@pbheight}{1.2pt}
\newlength{\SimpleUUlm@pbwidth}
\newcommand{\SimpleUUlm@progressbar}{%
    % \inserttotalframenumber is 0 on the first compilation (aux not yet written)
    \ifnum\inserttotalframenumber>0
        \setlength{\SimpleUUlm@pbwidth}{%
            \dimexpr(\linewidth/1000)*%
                \numexpr1000*\insertframenumber/\inserttotalframenumber\relax\relax}%
    \else
        \setlength{\SimpleUUlm@pbwidth}{0pt}%
    \fi
    \usebeamercolor{progress bar}%
    \makebox[\linewidth][l]{%
        \rlap{\color{bg}\rule{\linewidth}{\SimpleUUlm@pbheight}}%
        \color{fg}\rule{\SimpleUUlm@pbwidth}{\SimpleUUlm@pbheight}%
    }%
}

% frame title customization
\setbeamertemplate{frametitle}{%
    \vspace*{0.5em}%
    \bfseries\insertframetitle\par
    \ifx\insertframesubtitle\@empty\else
        \vskip2pt
        {\normalfont\small\usebeamercolor[fg]{framesubtitle}\insertframesubtitle\par}%
    \fi
    \vskip-6pt
    \ifdefstring{\SimpleUUlm@pbenabled}{true}%
        {\SimpleUUlm@progressbar}%
        {\makebox[\linewidth][l]{\rule{\linewidth}{\SimpleUUlm@pbheight}}}%
    \vspace{-0.1em}%
}

% title page customization
\setbeamertemplate{title page}{%
    \vspace{6em}%
    \begingroup
    \centering
    %
    \begin{beamercolorbox}[sep=10pt,center]{title}
        \usebeamerfont{title}\inserttitle\par%
        \ifx\insertsubtitle\@empty%
        \else%
        \vskip0.25em%
        {\usebeamerfont{subtitle}\usebeamercolor[fg]{subtitle}\insertsubtitle\par}%
        \fi%
    \end{beamercolorbox}%
    \vskip0.5em\par
    %
    \begin{beamercolorbox}[sep=8pt,center]{author}
        \usebeamerfont{author}\insertauthor
    \end{beamercolorbox}%
    \vskip-1em
    %
    \begin{beamercolorbox}[sep=8pt,center]{institute}
        \usebeamerfont{institute}\insertinstitute
    \end{beamercolorbox}%
    %
    \begin{beamercolorbox}[sep=8pt,center]{date}
        \usebeamerfont{date}\insertdate
    \end{beamercolorbox}\vskip0.5em
    %
    {\usebeamercolor[fg]{titlegraphic}\inserttitlegraphic\par}%
    \endgroup
    \vfill
}
